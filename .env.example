# ---------------------------------------------------------------------------
# Playstack — copy to .env and fill in every CHANGE_ME below. Never commit .env.
#
# This file is a TEMPLATE and is committed to git: it must never contain a real
# value. docker-compose reads these same vars from .env and has no fallback
# defaults, so an unset var fails loudly at `docker compose up` instead of
# silently standing up Postgres with a password that is public on GitHub.
# ---------------------------------------------------------------------------

# --- Database -------------------------------------------------------------
POSTGRES_USER=playstack
POSTGRES_PASSWORD=CHANGE_ME_local_db_password
POSTGRES_DB=playstack
POSTGRES_PORT=5432

# Prisma reads this one var. The user/password/port MUST match the POSTGRES_*
# values above — they are not derived from them.
DATABASE_URL="postgresql://playstack:CHANGE_ME_local_db_password@localhost:5432/playstack?schema=public"

# --- Auth -----------------------------------------------------------------
# Two DIFFERENT secrets: a leaked access secret must not let an attacker mint
# refresh tokens. Generate each with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGE_ME_run_openssl_rand_base64_48_again
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# --- API ------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# --- Web ------------------------------------------------------------------
# NEXT_PUBLIC_ vars are inlined into the browser bundle — never put a secret here.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- pgAdmin (local dev only) --------------------------------------------
PGADMIN_EMAIL=admin@playstack.dev
PGADMIN_PASSWORD=CHANGE_ME_local_pgadmin_password
PGADMIN_PORT=5050
