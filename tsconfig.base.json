{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    // strict alone still lets `arr[i]` claim to be defined and lets unset
    // optional props pass as `undefined`. Both bite hard in permission code.
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    // Both apps import the shared package by name, never by relative path,
    // so the matrix has exactly one import specifier across the monorepo.
    "baseUrl": ".",
    "paths": {
      "@playstack/shared": ["packages/shared/src/index.ts"],
      "@playstack/shared/*": ["packages/shared/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
